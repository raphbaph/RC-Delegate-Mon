# Example: https://forum.example.com
DISCOURSE_BASE_URL=

# Admin API credentials
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=

# Comma-separated usernames to monitor
DISCOURSE_MONITORED_USERNAMES=

# Optional: where SQLite DB is stored
# DISCOURSE_MONITOR_DB_PATH=./data/discourse_monitor.db

# Optional: endpoint returning cumulative time_read + likes_received
# Default: /u/{username}.json
# DISCOURSE_USER_ENDPOINT_TEMPLATE=/u/{username}.json
